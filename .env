# Where the NexusPoll backend lives. Used by the Vite dev proxy.
# In production the Vue app is usually served from the same origin as the API,
# so VITE_API_BASE can stay empty (requests go to the current host).
VITE_API_TARGET=https://dato.statistikam.uz

# Base URL the app uses for REST + socket.io.
# Empty = same origin (recommended in prod / when using the dev proxy).
# Set to https://dato.statistikam.uz to hit the backend directly.
VITE_API_BASE=
